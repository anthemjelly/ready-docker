FROM anthemjelly/ready-docker-python:latest

USER appuser
WORKDIR /opt/python-deps

COPY --chown=appuser:appuser lang/python/requirements/discord.txt ./requirements.txt

RUN ./venv/bin/pip install --no-cache-dir -r ./requirements.txt

WORKDIR /app
EXPOSE 8100

CMD ["tail", "-f", "/dev/null"]